# AWS Configuration Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# AWS Account Information
AWS_ACCOUNT_ID=your_account_id_here
AWS_REGION=eu-central-1

# ECR Repository
ECR_REPOSITORY_URI=your_account_id.dkr.ecr.your_region.amazonaws.com/your_repo_name

# Lambda Function
LAMBDA_FUNCTION_NAME=your_function_name

# Application Configuration
BGCHOF_CFG_CFG_DATAFILE_PREFIX=/tmp/.bgchofcache

# Deployment Configuration (Optional - defaults provided)
# Docker image tag to use for deployment
IMAGE_TAG=latest

# Prefix for backup tags (backup images will be tagged as backup-YYYYMMDD-HHMMSS)
BACKUP_TAG_PREFIX=backup

# Path to Dockerfile for Lambda deployment
DOCKERFILE_PATH=Dockerfile.lambda

# Deployment log file (optional - logs to console if not set)
# DEPLOYMENT_LOG_FILE=deployment.log